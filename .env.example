# Copy to:
#   apps/web/.env.local
#   apps/mobile/.env
# Restart dev servers after changes.

# --- Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_jwt

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_jwt

# --- Web only — Mapbox (https://account.mapbox.com/ → Access tokens) ---
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_default_public_token

# --- Server / workers only (never NEXT_PUBLIC_ / EXPO_PUBLIC_) ---
QDRANT_URL=
QDRANT_API_KEY=

# Gemini: use Supabase Edge secrets in production, or gitignored supabase/.env for `supabase functions serve`:
#   supabase secrets set GEMINI_API_KEY=... --project-ref YOUR_PROJECT_REF
#   supabase secrets set GEMINI_MODEL=gemini-2.5-flash --project-ref YOUR_PROJECT_REF
