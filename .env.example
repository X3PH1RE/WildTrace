# Web dashboard — Mapbox (public token, safe to expose with URL restrictions)
# How to get a token:
#   1. https://account.mapbox.com/ → sign up / log in
#   2. Account → Access tokens → Create a token (default public scopes are OK for maps)
#   3. Paste below as NEXT_PUBLIC_MAPBOX_TOKEN
NEXT_PUBLIC_MAPBOX_TOKEN=

# Qdrant (future re-ID worker only — never ship to browsers)
QDRANT_URL=
QDRANT_API_KEY=

# -----------------------------------------------------------------------------
